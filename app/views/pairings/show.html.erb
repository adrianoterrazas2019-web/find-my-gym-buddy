<%= turbo_stream_from "chat_#{@chat.id}" %>
<%= turbo_stream_from "direct_chat_#{@direct_chat.id}" %>

<h1>Pairing between <%= current_user.user_profile&.name %> and <%= @partner.user_profile&.name %></h1>
<div style="display: flex; gap: 1rem;">
  <div style="flex: 1;">
    <% if current_user.user_profile&.photo&.attached? %>
      <%= cl_image_tag current_user.user_profile.photo.key, width: 100, height: 100, crop: :fill %>
    <% end %>
    <h2><%= current_user.user_profile&.name || current_user.email %></h2>
    <% if current_user.user_profile %>
      <p><%= current_user.user_profile.goal %></p>
      <p><%= current_user.user_profile.experience %></p>
    <% end %>
  </div>

  <div style="flex: 2;" data-controller="tabs">
    <div class="flex border-b border-gray-200">
      <button data-tabs-target="tab"
              data-action="tabs#switch"
              data-tabs-tab-param="messages"
              data-tab-name="messages"
              class="px-4 py-2 text-sm font-medium border-b-2 -mb-px"
              aria-selected="false">
        Messages
      </button>
      <button data-tabs-target="tab"
              data-action="tabs#switch"
              data-tabs-tab-param="workout-plans"
              data-tab-name="workout-plans"
              class="px-4 py-2 text-sm font-medium border-b-2 -mb-px"
              aria-selected="false">
        Workout Plans
      </button>
      <button data-tabs-target="tab"
              data-action="tabs#switch"
              data-tabs-tab-param="calendar"
              data-tab-name="calendar"
              class="px-4 py-2 text-sm font-medium border-b-2 -mb-px"
              aria-selected="false">
        Calendar
      </button>
    </div>

    <div data-tabs-target="panel" data-tab-name="messages" hidden>
      <div id="direct_messages_<%= @pairing.id %>">
        <% @direct_chat.direct_messages.order(:created_at).each do |direct_message| %>
          <%= render direct_message %>
        <% end %>
      </div>
      <%= render "direct_messages/form", pairing: @pairing %>
    </div>

    <div data-tabs-target="panel" data-tab-name="workout-plans">
      <div id="messages" class="mt-4">
        <% @chat.messages.each do |message| %>
          <%= render message %>
        <% end %>
      </div>
      <%= render "messages/form", chat: @chat, message: @message %>
    </div>

    <div data-tabs-target="panel" data-tab-name="calendar" hidden>
      <p class="text-gray-500 text-sm mt-4">Calendar coming soon.</p>
    </div>
  </div>

  <div style="flex: 1;">
    <% if @partner.user_profile&.photo&.attached? %>
      <%= cl_image_tag @partner.user_profile.photo.key, width: 100, height: 100, crop: :fill %>
    <% end %>
    <h2><%= @partner.user_profile&.name || @partner.email %></h2>
    <% if @partner.user_profile %>
      <p><%= @partner.user_profile.goal %></p>
      <p><%= @partner.user_profile.experience %></p>
    <% end %>
  </div>
</div>

<%= link_to "Back to pairings", pairings_path %>
