<%= render layout: "shared/auth_card", locals: { title: "Welcome back" } do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

    <div class="form-field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
    </div>

    <div class="form-field">
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2 mb-6">
        <%= f.check_box :remember_me, class: "accent-gym-primary" %>
        <%= f.label :remember_me, class: "text-sm text-gym-text/65 cursor-pointer" %>
      </div>
    <% end %>

    <%= f.submit "Log in", class: "btn-primary w-full mt-2" %>

  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
