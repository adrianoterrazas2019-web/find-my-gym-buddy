<%= render layout: "shared/auth_card", locals: { title: "Create your account" } do %>
  <%= form_for(@user, as: :user, url: registration_path(:user)) do |f| %>

    <%= render "devise/shared/error_messages", resource: @user %>

    <div class="form-field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
    </div>

    <div class="form-field">
      <%= f.label :password, class: "form-label" %>
      <% if @minimum_password_length %>
        <span class="form-hint"><%= @minimum_password_length %> characters minimum</span>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-input mt-1", placeholder: "••••••••" %>
    </div>

    <div class="form-field">
      <%= f.label :password_confirmation, class: "form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
    </div>

    <div class="form-divider"></div>
    <p class="form-section-title">Profile Information</p>

    <%= f.fields_for :user_profile do |profile| %>

      <div class="form-field">
        <%= profile.label :name, class: "form-label" %>
        <%= profile.text_field :name, class: "form-input", placeholder: "Your name" %>
        <div class="flex items-center gap-2 mt-2">
          <%= profile.check_box :show_name, class: "accent-gym-primary" %>
          <%= profile.label :show_name, "Show name to other users", class: "text-sm text-gym-text/65 cursor-pointer" %>
        </div>
      </div>

      <div class="form-field">
        <%= profile.label :birthdate, class: "form-label" %>
        <%= profile.date_field :birthdate, class: "form-input" %>
      </div>

      <div class="form-field">
        <%= profile.label :gender, class: "form-label" %>
        <%= profile.select :gender, UserProfile::GENDERS, {}, class: "form-select" %>
        <div class="flex items-center gap-2 mt-2">
          <%= profile.check_box :show_gender, class: "accent-gym-primary" %>
          <%= profile.label :show_gender, "Show gender to other users", class: "text-sm text-gym-text/65 cursor-pointer" %>
        </div>
      </div>

    <% end %>

    <%= f.submit "Create account", class: "btn-primary w-full mt-2" %>

  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
