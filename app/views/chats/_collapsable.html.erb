<details class="ai-chat-collapsable">
  <summary class="ai-chat-summary">
    Chat with your coach <strong>AIrnie</strong>
    <svg class="ai-chat-chevron" xmlns="http://www.w3.org/2000/svg" fill="none"
         viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
    </svg>
  </summary>

  <div class="ai-chat-body">
    <div class="flex justify-end mb-2 relative z-10">
      <%= button_to "Clear chat", clear_chat_path(chat),
            method: :delete,
            data: { turbo_confirm: "Clear the conversation history?" },
            class: "btn-danger text-xs px-3 py-1.5" %>
    </div>

    <div id="messages" class="ai-chat-messages">
      <% chat.messages.visible.order(:created_at).each do |message| %>
        <%= render message %>
      <% end %>
    </div>

    <%= render "messages/form", chat: chat, message: message %>
  </div>
</details>
