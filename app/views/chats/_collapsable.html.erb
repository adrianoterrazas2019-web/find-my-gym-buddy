<details class="mt-4 card p-4">
  <summary class="cursor-pointer font-medium text-gym-text/80 hover:text-gym-text transition-colors">
    Chat with your coach <strong>AIrnold</strong>
  </summary>
  <div class="mt-4" id="messages">
    <% chat.messages.visible.order(:created_at).each do |message| %>
      <%= render message %>
    <% end %>
  </div>
  <%= render "messages/form", chat: chat, message: message %>
</details>
