<% assistant ||= local_assigns[:message] %>
<div id="message_<%= assistant.id %>" class="ai-message ai-message-assistant">
  <div class="ai-bubble-col ai-bubble-col-ai">
    <span class="ai-badge ai-badge-ai">AIrnold</span>
    <div id="message_<%= assistant.id %>_content" class="ai-bubble ai-bubble-ai"><%= assistant.content %></div>
    <time class="ai-timestamp"
          data-controller="local-time"
          datetime="<%= assistant.created_at&.utc&.iso8601 %>">
      <%= assistant.created_at&.strftime("%H:%M") %>
    </time>
  </div>
</div>
