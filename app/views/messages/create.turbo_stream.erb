<% if defined?(@chat) && @chat.present? %>
  <%= turbo_stream.replace "new_message" do %>
    <%= render "messages/form",
      chat: @chat,
      message: @message,
      readonly: true %>
  <% end %>
  <%= turbo_stream.append "messages" do %>
    <%= render "messages/thinking" %>
  <% end %>
<% end %>
