<div class="page-container">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gym-text">My Calendar</h1>

    <%= link_to "Add Entry", new_calendar_entry_path, class: "btn-primary" %>
  </div>

  <%= month_calendar(events: @calendar_entries) do |date, entries| %>
    <span class="calendar-day-num"><%= date.day %></span>
    <% entries.each do |entry| %>
      <% destination = entry.workout_plan_id ? workout_plan_path(entry.workout_plan_id) : calendar_entry_path(entry) %>
      <%= link_to entry.title, destination, class: "calendar-entry-pill" %>
    <% end %>
  <% end %>
</div>
