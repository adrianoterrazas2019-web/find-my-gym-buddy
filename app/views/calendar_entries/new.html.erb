<div class="page-container">
  <div class="auth-card">
    <h2 class="auth-title">New Calendar Entry</h2>

<%= form_with model: @calendar_entry do |f| %>

  <%= f.label :start_time %>
  <%= f.datetime_field :start_time %>

  <%= f.label :end_time %>
  <%= f.datetime_field :end_time %>

  <%= f.label :title %>
  <%= f.text_field :title, class: "form-input" %>


      <div class="form-field">
        <%= f.label :location, class: "form-label" %>
        <%= f.text_field :location, class: "form-input", placeholder: "e.g. Local gym" %>
      </div>

      <div class="form-field">
        <%= f.label :entry_type, "Type", class: "form-label" %>
        <%= f.text_field :entry_type, class: "form-input", placeholder: "e.g. Workout" %>
      </div>

      <div class="form-field">
        <%= f.label :note, class: "form-label" %>
        <%= f.text_area :note, class: "form-input", rows: 3, placeholder: "Optional note…" %>
      </div>

      <div class="flex gap-3 justify-end pt-4 border-t border-black/10 dark:border-white/10 mt-6">
        <%= link_to "Cancel", calendars_path, class: "btn-ghost" %>
        <%= f.submit "Save Entry", class: "btn-primary" %>
      </div>

    <% end %>
  </div>
</div>
