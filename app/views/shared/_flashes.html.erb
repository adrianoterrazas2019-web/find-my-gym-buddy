<% if notice %>
  <div data-controller="flash" class="flex items-center gap-3 mx-4 mt-3 px-4 py-3 rounded-xl bg-gym-primary/15 border border-gym-primary/30 text-gym-text text-sm" role="alert">
    <span class="flex-1"><%= notice %></span>
    <button type="button" data-action="click->flash#dismiss" class="text-gym-text/50 hover:text-gym-text font-bold leading-none" aria-label="Close">&times;</button>
  </div>
<% end %>
<% if alert %>
  <div data-controller="flash" class="flex items-center gap-3 mx-4 mt-3 px-4 py-3 rounded-xl bg-yellow-500/15 border border-yellow-500/30 text-yellow-100 text-sm" role="alert">
    <span class="flex-1"><%= alert %></span>
    <button type="button" data-action="click->flash#dismiss" class="text-yellow-200/60 hover:text-yellow-100 font-bold leading-none" aria-label="Close">&times;</button>
  </div>
<% end %>
