<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Find My Gym Buddy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Find My Gym Buddy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Restore theme before CSS renders to prevent flash of wrong theme %>
    <script nonce="<%= content_security_policy_nonce %>">
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.remove('dark');
      }
      var ct = localStorage.getItem('colorTheme');
      if (ct && ct !== 'orange') {
        document.documentElement.dataset.theme = ct;
      }
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "simple_calendar", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
