<div class="page-container">
  <h1 class="text-3xl font-black text-gym-text mb-6">Find a Gym Buddy</h1>

  <%# Filter form %>
  <div class="card p-6 mb-8">
    <%= form_with url: user_profiles_path, method: :get do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">

        <div class="form-field mb-0 sm:col-span-2 lg:col-span-3">
          <%= f.label :search, "Search by name or location", class: "form-label" %>
          <%= f.text_field :search, value: params[:search],
                class: "form-input", placeholder: "e.g. Alex or London…" %>
        </div>

        <div class="form-field mb-0">
          <%= f.label :experience, class: "form-label" %>
          <%= f.select :experience,
                options_for_select([["Any level", ""]] + UserProfile::EXPERIENCES.map { |e| [e.capitalize, e] }, params[:experience]),
                {}, class: "form-select" %>
        </div>

        <div class="form-field mb-0">
          <%= f.label :gender, class: "form-label" %>
          <%= f.select :gender,
                options_for_select([["Any gender", ""]] + UserProfile::GENDERS.map { |g| [g.capitalize, g] }, params[:gender]),
                {}, class: "form-select" %>
        </div>

        <%# Goals — multi-select checkboxes %>
        <div class="form-field mb-0 sm:col-span-2 lg:col-span-2">
          <p class="form-label">Goals <span class="font-normal text-gym-text/40">(select one or more)</span></p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 mt-1.5">
            <% UserProfile::GOALS.each do |goal| %>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gym-text/70 hover:text-gym-text transition-colors">
                <%= check_box_tag "goals[]", goal, Array(params[:goals]).include?(goal),
                      class: "accent-gym-primary" %>
                <%= goal.humanize %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="form-field mb-0" data-controller="pair-score">
          <%= f.label :min_score, "Min pair score", class: "form-label" %>
          <div class="flex items-center gap-3 mt-1.5">
            <%= f.range_field :min_score,
                  value: params[:min_score].presence || 0, min: 0, max: 100, step: 5,
                  class: "w-full accent-gym-primary",
                  data: { action: "input->pair-score#updateLabel" } %>
            <span class="profile-score shrink-0" data-pair-score-target="label">
              <%= params[:min_score].presence || 0 %>
            </span>
          </div>
        </div>

      </div>

      <div class="flex items-center gap-3 pt-4 border-t border-black/10 dark:border-white/10">
        <%= f.submit "Search", class: "btn-primary" %>
        <%= link_to "Clear", user_profiles_path, class: "btn-ghost" %>
      </div>
    <% end %>
  </div>

  <p class="text-sm text-gym-text/50 mb-4"><%= pluralize(@profiles.count, "buddy") %> found</p>

  <%# Profile grid %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @profiles.each do |profile| %>
      <%= link_to user_profile_path(profile), class: "profile-card group" do %>

        <%# Avatar + name %>
        <div class="flex items-center gap-3">
          <% if profile.photo.attached? %>
            <%= cl_image_tag profile.photo.key, width: 56, height: 56, crop: :fill,
                  class: "w-14 h-14 rounded-full object-cover shrink-0
                          ring-2 ring-gym-primary/20 group-hover:ring-gym-primary/50
                          transition-all duration-200" %>
          <% else %>
            <div class="profile-avatar-placeholder w-14 h-14 text-xl">
              <%= (profile.show_name? ? profile.name : "?").first.upcase %>
            </div>
          <% end %>

          <div class="min-w-0">
            <p class="font-semibold text-gym-text truncate group-hover:text-gym-primary transition-colors duration-200">
              <%= profile.show_name? ? profile.name : "Anonymous" %>
            </p>
            <p class="text-xs text-gym-text/50 truncate">
              <%= profile.address.presence || "Location not set" %>
            </p>
          </div>
        </div>

        <%# Badges %>
        <div class="flex flex-wrap gap-2">
          <% if profile.experience.present? %>
            <span class="profile-badge profile-badge-primary"><%= profile.experience.capitalize %></span>
          <% end %>
          <% if profile.goal.present? %>
            <span class="profile-badge profile-badge-secondary"><%= profile.goal.humanize %></span>
          <% end %>
          <% if profile.show_gender? && profile.gender.present? %>
            <span class="profile-badge profile-badge-muted"><%= profile.gender.capitalize %></span>
          <% end %>
        </div>

        <%# Pair score %>
        <div class="flex items-center justify-between pt-3 border-t border-black/8 dark:border-white/8">
          <span class="text-xs text-gym-text/50">Pair score</span>
          <span class="profile-score"><%= @scores[profile] %>/100</span>
        </div>

      <% end %>
    <% end %>
  </div>
</div>
