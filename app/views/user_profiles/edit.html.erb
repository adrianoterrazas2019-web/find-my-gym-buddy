<div class="page-container">
  <div class="auth-card">
    <h2 class="auth-title">Edit Profile</h2>

    <% if @profile.errors.any? %>
      <div class="form-errors">
        <%= pluralize(@profile.errors.count, "error") %> prevented your profile from being saved:
        <ul>
          <% @profile.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @profile, url: user_profile_path, method: :patch do |f| %>

      <div class="form-field">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-input", placeholder: "Your name" %>
      </div>

      <div class="form-field">
        <%= f.label :birthdate, class: "form-label" %>
        <%= f.date_field :birthdate, class: "form-input" %>
      </div>

      <div class="form-field">
        <%= f.label :gender, class: "form-label" %>
        <%= f.select :gender, UserProfile::GENDERS, {}, class: "form-select" %>
      </div>

      <div class="form-field">
        <%= f.label :address, "Location", class: "form-label" %>
        <%= f.text_field :address, class: "form-input", placeholder: "City or postcode" %>
      </div>

      <div class="form-field">
        <%= f.label :goal, class: "form-label" %>
        <%= f.select :goal,
              options_for_select([["— select —", ""]] + UserProfile::GOALS.map { |g| [g.humanize, g] }, @profile.goal),
              { include_blank: false }, class: "form-select" %>
      </div>

      <div class="form-field">
        <%= f.label :experience, class: "form-label" %>
        <%= f.select :experience,
              options_for_select([["— select —", ""]] + UserProfile::EXPERIENCES.map { |e| [e.capitalize, e] }, @profile.experience),
              { include_blank: false }, class: "form-select" %>
      </div>

      <div class="form-field">
        <%= f.label :bio, "About me", class: "form-label" %>
        <%= f.text_area :bio, class: "form-input", rows: 4, placeholder: "Tell potential gym buddies a bit about yourself…" %>
      </div>

      <div class="form-field">
        <%= f.label :photo, "Profile picture", class: "form-label" %>
        <% if @profile.photo.attached? %>
          <div class="mb-3 flex items-center gap-3">
            <%= cl_image_tag @profile.photo.key, width: 56, height: 56, crop: :fill,
                  class: "w-14 h-14 rounded-full object-cover ring-2 ring-gym-primary/30" %>
            <span class="text-xs text-gym-text/50">Current photo</span>
          </div>
        <% end %>
        <%= f.file_field :photo, class: "block w-full text-sm text-gym-text/70
              file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0
              file:text-sm file:font-semibold file:cursor-pointer
              file:transition-all file:duration-200
              file:text-gym-primary
              file:bg-gym-primary/10 file:hover:bg-gym-primary/20" %>
        <p class="form-hint">JPG, PNG or GIF — max 5 MB</p>
      </div>

      <div class="flex gap-3 justify-end pt-4 border-t border-black/10 dark:border-white/10 mt-6">
        <%= link_to "Cancel", user_profile_path(@profile), class: "btn-ghost" %>
        <%= f.submit "Save Profile", class: "btn-primary" %>
      </div>

    <% end %>
  </div>
</div>
