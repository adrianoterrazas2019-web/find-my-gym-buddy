<h1>Edit Profile</h1>

<% if @profile.errors.any? %>
  <ul>
    <% @profile.errors.full_messages.each do |msg| %>
      <li><%= msg %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @profile,
              url: user_profile_path,
              method: :patch do |f| %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :birthdate %>
    <%= f.date_field :birthdate %>
  </div>

  <div>
    <%= f.label :gender %>
    <%= f.select :gender, UserProfile::GENDERS %>
  </div>

  <div>
    <%= f.label :address, "Location" %>
    <%= f.text_field :address %>
  </div>

  <div>
    <%= f.label :goal %>
    <%= f.select :goal,
          options_for_select([["— select —", ""]] + UserProfile::GOALS.map { |g| [g.humanize, g] }, @profile.goal),
          include_blank: false %>
  </div>

  <div>
    <%= f.label :experience %>
    <%= f.select :experience,
          options_for_select([["— select —", ""]] + UserProfile::EXPERIENCES.map { |e| [e.capitalize, e] }, @profile.experience),
          include_blank: false %>
  </div>

  <%= f.submit "Save Profile" %>

<% end %>
