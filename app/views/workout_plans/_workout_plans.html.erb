<div id="workout_plans">
  <% if workout_plans.empty? %>
    <p>No workout plans yet.</p>
  <% else %>
    <ul>
      <% workout_plans.each do |plan| %>
        <li>
          <%= link_to plan.title.presence || "Workout Plan ##{plan.id}", workout_plan_path(plan) %>
          <% if plan.description.present? %>
            <p><%= plan.description %></p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
