<%= form_with model: workout_plan, url: url do |f| %>
  <% if workout_plan.errors.any? %>
    <div class="form-errors">
      <ul>
        <% workout_plan.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "e.g. Morning Power Circuit" %>
  </div>

  <div class="form-field">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-input", rows: 3,
          placeholder: "What's the focus of this plan?" %>
  </div>

  <div class="flex gap-3 justify-end pt-4 border-t border-black/10 dark:border-white/10 mt-6">
    <%= link_to "Cancel", :back, class: "btn-ghost" %>
    <%= f.submit class: "btn-primary" %>
  </div>
<% end %>
