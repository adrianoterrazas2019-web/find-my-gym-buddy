<%= turbo_stream.append "direct_messages" do %>
  <%= render "direct_messages/direct_message",
      direct_message: @direct_message,
      current_user: current_user %>
<% end %>

<%= turbo_stream.replace "direct_message_form_#{@pairing.id}" do %>
  <%= render "direct_messages/form", pairing: @pairing %>
<% end %>
