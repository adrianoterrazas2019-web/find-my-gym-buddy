<% self_message = direct_message.user_id == current_user.id %>
<% dm_user = direct_message.user %>
<div id="<%= dom_id(direct_message) %>" class="ai-message <%= self_message ? 'ai-message-user' : 'ai-message-assistant' %>">
  <% unless self_message %>
    <% if dm_user.user_profile&.photo&.attached? %>
      <%= cl_image_tag dm_user.user_profile.photo.key, width: 28, height: 28, crop: :fill, class: "ai-avatar" %>
    <% else %>
      <div class="ai-avatar flex items-center justify-center bg-gym-primary/15 text-gym-primary font-bold text-xs">
        <%= dm_user.user_profile&.name&.first&.upcase || "?" %>
      </div>
    <% end %>
  <% end %>
  <div class="ai-bubble-col <%= self_message ? 'ai-bubble-col-user' : 'ai-bubble-col-ai' %>">
    <span class="ai-badge <%= self_message ? 'ai-badge-user' : 'ai-badge-partner' %>">
      <%= dm_user.user_profile&.name || dm_user.email %>
    </span>
    <div class="ai-bubble <%= self_message ? 'ai-bubble-user' : 'ai-bubble-partner' %>"><%= direct_message.content %></div>
    <time class="ai-timestamp" data-controller="local-time" datetime="<%= direct_message.created_at.utc.iso8601 %>">
      <%= direct_message.created_at.utc.strftime("%H:%M") %>
    </time>
  </div>
  <% if self_message %>
    <% if dm_user.user_profile&.photo&.attached? %>
      <%= cl_image_tag dm_user.user_profile.photo.key, width: 28, height: 28, crop: :fill, class: "ai-avatar" %>
    <% else %>
      <div class="ai-avatar flex items-center justify-center bg-gym-primary/15 text-gym-primary font-bold text-xs">
        <%= dm_user.user_profile&.name&.first&.upcase || "?" %>
      </div>
    <% end %>
  <% end %>
</div>
